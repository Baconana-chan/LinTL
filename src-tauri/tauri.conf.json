{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lintl",
  "version": "1.0.0",
  "identifier": "com.baconana.lintl",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "lintl",
        "width": 1280,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
